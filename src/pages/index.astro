---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import CategoryGroup from '../components/CategoryGroup.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ProjectModal from '../components/ProjectModal.astro';
import { resolveCoverImage } from '../utils/cover';

const allProjects = await getCollection('projects');
const projects = allProjects.filter((p) => p.data.tab === 'in-camera-vfx');

// Group by category, preserving order within each
const byCategory = new Map<string, typeof projects>();
for (const p of projects) {
  const cat = p.data.category;
  if (!byCategory.has(cat)) byCategory.set(cat, []);
  byCategory.get(cat)!.push(p);
}

const categoryOrder = ['Media System', 'Camera', 'Camera Tracking', 'Stage Control', 'Previz', 'Pipeline'];
const sortedCategories = [
  ...categoryOrder.filter((c) => byCategory.has(c)),
  ...[...byCategory.keys()].filter((c) => !categoryOrder.includes(c)),
];

for (const cat of sortedCategories) {
  byCategory.get(cat)!.sort((a, b) => a.data.order - b.data.order);
}

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="In-Camera VFX · NABA - Virtual Studio" activeTab="in-camera-vfx">
  {sortedCategories.map((category) => (
    <CategoryGroup title={category}>
      {byCategory.get(category)!.map((project) => (
        <ProjectCard
          title={project.data.title}
          slug={project.slug}
          cover={resolveCoverImage(project.data.cover ?? project.slug, base)}
          status={project.data.status}
        />
      ))}
    </CategoryGroup>
  ))}

  {projects.length === 0 && (
    <p class="text-center text-text-muted py-20">No projects yet. Add Markdown files to <code class="px-1.5 py-0.5 bg-card-bg border border-border-subtle rounded text-text-secondary">src/content/projects/</code>.</p>
  )}

  <ProjectModal projects={projects} />
</BaseLayout>
