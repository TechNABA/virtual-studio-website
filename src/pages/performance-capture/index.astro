---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryGroup from '../../components/CategoryGroup.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import ProjectModal from '../../components/ProjectModal.astro';
import { resolveCoverImage } from '../../utils/cover';

const allProjects = await getCollection('projects');
const projects = allProjects.filter((p) => p.data.tab === 'performance-capture');

const byCategory = new Map<string, typeof projects>();
for (const p of projects) {
  const cat = p.data.category;
  if (!byCategory.has(cat)) byCategory.set(cat, []);
  byCategory.get(cat)!.push(p);
}
for (const [, list] of byCategory) {
  list.sort((a, b) => a.data.order - b.data.order);
}

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Performance Capture · NABA - Virtual Studio" activeTab="performance-capture">
  {[...byCategory.keys()].map((category) => (
    <CategoryGroup title={category}>
      {byCategory.get(category)!.map((project) => (
        <ProjectCard
          title={project.data.title}
          slug={project.slug}
          cover={resolveCoverImage(project.data.cover ?? project.slug, base)}
          status={project.data.status}
        />
      ))}
    </CategoryGroup>
  ))}

  {projects.length === 0 && (
    <div class="text-center py-24">
      <p class="text-text-secondary text-sm">No Performance Capture projects yet.</p>
      <p class="text-text-muted text-xs mt-2">Add them by creating files in <code class="px-1.5 py-0.5 bg-card-bg border border-border-subtle rounded text-text-secondary">src/content/projects/</code> with <code class="px-1.5 py-0.5 bg-card-bg border border-border-subtle rounded text-text-secondary">tab: "performance-capture"</code>.</p>
    </div>
  )}

  <ProjectModal projects={projects} />
</BaseLayout>
